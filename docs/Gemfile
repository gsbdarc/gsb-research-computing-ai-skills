source 'https://rubygems.org'

# Modern Jekyll directly (not the legacy `github-pages` gem, which pins to
# Jekyll 3.9 and breaks on Ruby 3.4+). For GitHub Pages deployment, use the
# `actions/jekyll-build-pages` Action instead of the legacy gem.
gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"
gem "webrick", "~> 1.8"

# Gems that used to live in the Ruby standard library but were promoted to
# bundled gems in Ruby 3.4+. Jekyll's dependencies still try to `require` them
# but they're no longer loaded by default. Listing them here makes Bundler
# install them and put them on the load path.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
